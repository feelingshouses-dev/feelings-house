{
  "name": "feelings-houses-frontend",
  "version": "1.0.0",
  "installCommand": "yarn install",
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "env": {
    "REACT_APP_BACKEND_URL": {
      "description": "Backend API URL from Render",
